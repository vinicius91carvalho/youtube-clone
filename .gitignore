# Ignore video files by default...
*.mp4
# ...but keep the seed video that defines the initial fake-gcs bucket structure
!data/gcs-data/neetcode-youtube-course-raw-videos/example-epic-of-gilgamesh.mp4

# Local runtime state written by fake-gcs / the processor at run time,
# while keeping the committed directory structure (via the .gitkeep markers).
data/video-processing-service/raw-videos/*
data/video-processing-service/processed-videos/*
data/gcs-data/neetcode-youtube-course-processed-videos/*
!data/**/.gitkeep
*.bucketMetadata